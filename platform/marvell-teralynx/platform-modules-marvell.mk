# Teralynx 10 Platform

TL10_DBMVTX9180_VERSION = 1.0
D64P512T_VERSION = 1.0

export TL10_DBMVTX9180_VERSION
export D64P512T_VERSION

TL10_DBMVTX9180_PLATFORM = sonic-platform-marvell-dbmvtx9180_$(TL10_DBMVTX9180_VERSION)_$(CONFIGURED_ARCH).deb
$(TL10_DBMVTX9180_PLATFORM)_SRC_PATH = $(PLATFORM_PATH)/sonic-platform-marvell-teralynx
$(TL10_DBMVTX9180_PLATFORM)_DEPENDS += $(LINUX_HEADERS) $(LINUX_HEADERS_COMMON) $(PDDF_PLATFORM_MODULE_SYM)
$(TL10_DBMVTX9180_PLATFORM)_PLATFORM = x86_64-marvell_dbmvtx9180-r0

SONIC_DPKG_DEBS += $(TL10_DBMVTX9180_PLATFORM)

D64P512T_PLATFORM_MODULE = sonic-platform-marvell-d64p512t_$(D64P512T_VERSION)_$(CONFIGURED_ARCH).deb
$(D64P512T_PLATFORM_MODULE)_DEPENDS += $(LINUX_HEADERS) $(LINUX_HEADERS_COMMON) $(PDDF_PLATFORM_MODULE_SYM)
$(D64P512T_PLATFORM_MODULE)_PLATFORM = x86_64-marvell_d64p512t-r0
$(eval $(call add_extra_package,$(TL10_DBMVTX9180_PLATFORM),$(D64P512T_PLATFORM_MODULE)))