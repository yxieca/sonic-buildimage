
MPATH       := $($(ARISTA_PLATFORM_MODULE_ALL)_SRC_PATH)
DEP_FILES   := $(SONIC_COMMON_FILES_LIST) platform/aspeed/platform-modules-arista.mk platform/aspeed/platform-modules-arista.dep
DEP_FILES   += $(SONIC_COMMON_BASE_FILES_LIST)
SMDEP_FILES := $(addprefix $(MPATH)/,$(shell cd $(MPATH) && git ls-files))

$(ARISTA_PLATFORM_MODULE_ALL)_CACHE_MODE  := GIT_CONTENT_SHA
$(ARISTA_PLATFORM_MODULE_ALL)_DEP_FLAGS   := $(SONIC_COMMON_FLAGS_LIST)
$(ARISTA_PLATFORM_MODULE_ALL)_DEP_FILES   := $(DEP_FILES)
$(ARISTA_PLATFORM_MODULE_ALL)_SMDEP_FILES := $(SMDEP_FILES)
$(ARISTA_PLATFORM_MODULE_ALL)_SMDEP_PATHS := $(MPATH)
