diff --git a/lib/vty.c b/lib/vty.c
index b4e59a2a7b..f62ee33a59 100644
--- a/lib/vty.c
+++ b/lib/vty.c
@@ -42,6 +42,7 @@
 #include "json.h"
 #include "sockopt.h"
 #include "frregex_real.h"
